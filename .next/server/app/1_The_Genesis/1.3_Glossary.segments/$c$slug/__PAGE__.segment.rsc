73:["$","p","p-97",{"children":[["$","strong","strong-0",{"children":"Simulation (Control)"}],": Mathematical model predicting system behavior; enables design validation, tuning, operator training without risking real equipment."]}]
74:["$","p","p-98",{"children":[["$","strong","strong-0",{"children":"SLAM (Simultaneous Localization and Mapping)"}],": Robot inference of own pose AND map of environment from sensor data; enables autonomous navigation."]}]
75:["$","p","p-99",{"children":[["$","strong","strong-0",{"children":"Soft Actor-Critic (SAC)"}],": Deep RL algorithm maximizing reward + entropy (exploration); excellent sample efficiency, state-of-the-art for continuous control."]}]
76:["$","p","p-100",{"children":[["$","strong","strong-0",{"children":"Stability"}],": Property of system; small perturbations don't cause large responses; asymptotic stability → trajectories converge to equilibrium."]}]
77:["$","p","p-101",{"children":[["$","strong","strong-0",{"children":"State (Control)"}],": System variables determining future behavior; e.g., position, velocity, temperature. State-space representation: (\\dot{x} = Ax + Bu)."]}]
78:["$","p","p-102",{"children":[["$","strong","strong-0",{"children":"State Machine"}],": Discrete system with finite states and transitions; FSM fundamental to PLC logic and embedded systems."]}]
79:["$","p","p-103",{"children":[["$","strong","strong-0",{"children":"State-Space"}],": Mathematical representation using state vector (x(t)) rather than differential equations; enables matrix algebra, eigenvalue analysis."]}]
7a:["$","p","p-104",{"children":[["$","strong","strong-0",{"children":"Steady-State Error"}],": Difference between reference and actual output after transients decay; eliminated via integral action."]}]
7b:["$","hr","hr-19",{}]
7c:["$","h2","h2-19",{"children":"T"}]
7d:["$","p","p-105",{"children":[["$","strong","strong-0",{"children":"Task Space (Cartesian Space)"}],": Robot coordinates (3D position + orientation) contrasted with joint space (DOF angles)."]}]
7e:["$","p","p-106",{"children":[["$","strong","strong-0",{"children":"Temporal Logic"}],": Formal language expressing system properties over time; LTL (Linear Temporal Logic), MTL (Metric Temporal Logic)."]}]
7f:["$","p","p-107",{"children":[["$","strong","strong-0",{"children":"Time Constant"}],": Characteristic time for system response; (\\tau) in first-order: (y(t) = y_{ss}(1 - e^{-t/\\tau}))."]}]
80:["$","p","p-108",{"children":[["$","strong","strong-0",{"children":"Transfer Function"}],": Ratio of output to input in Laplace domain; (G(s) = Y(s)/U(s)). Captures system behavior for control design."]}]
81:["$","p","p-109",{"children":[["$","strong","strong-0",{"children":"Trajectory"}],": Path through state/configuration space over time; includes velocities, accelerations (contrasts with path, which is geometric)."]}]
82:["$","p","p-110",{"children":[["$","strong","strong-0",{"children":"Transient Response"}],": System behavior before reaching steady state; characterized by overshoot, settling time, rise time."]}]
83:["$","hr","hr-20",{}]
84:["$","h2","h2-20",{"children":"U"}]
85:["$","p","p-111",{"children":[["$","strong","strong-0",{"children":"Uncertainty (Robustness)"}],": Model mismatch, parameter variation, disturbances. Robust control maintains stability despite uncertainty bounds."]}]
86:["$","hr","hr-21",{}]
87:["$","h2","h2-21",{"children":"V"}]
88:["$","p","p-112",{"children":[["$","strong","strong-0",{"children":"Vision-Based Control"}],": Using camera feedback for control; enables manipulation, navigation; challenges: latency, occlusion."]}]
89:["$","hr","hr-22",{}]
8a:["$","h2","h2-22",{"children":"W"}]
8b:["$","p","p-113",{"children":[["$","strong","strong-0",{"children":"Workspace"}],": Reachable region for robot end-effector; bounded by joint limits, singular configurations."]}]
8c:["$","hr","hr-23",{}]
8d:["$","h2","h2-23",{"children":"X-Z"}]
8e:["$","p","p-114",{"children":[["$","strong","strong-0",{"children":"YOLO (You Only Look Once)"}],": Single-stage object detection neural network; real-time speed (~50 FPS), moderate accuracy (~85-90% mAP)."]}]
8f:["$","p","p-115",{"children":[["$","strong","strong-0",{"children":"Ziegler-Nichols Tuning"}],": PID tuning method inducing oscillation at stability boundary, deriving gain formulas; practical, heuristic."]}]
