2a:["$","strong","strong-2",{"children":"Impact"}]
2b:["$","h3","h3-6",{"children":"1968: Dick Morley's Programmable Logic Controller (PLC)"}]
2c:["$","p","p-7",{"children":[["$","strong","strong-0",{"children":"Event"}],": Dick Morley designs the first PLC for Bedford Associates.",["$","br","br-0",{}],"\n",["$","strong","strong-1",{"children":"Problem Solved"}],": Hard-wired relay logic circuits were inflexible and required complete rewiring for any process changes.",["$","br","br-1",{}],"\n",["$","strong","strong-2",{"children":"Solution"}],": Replace physical relays with solid-state switching; program the logic in software using \"ladder logic.\"",["$","br","br-2",{}],"\n",["$","strong","strong-3",{"children":"Impact"}],": Completely transforms industrial process control, enabling rapid reconfiguration of factory lines."]}]
2d:["$","h3","h3-7",{"children":"1973: 6-Axis Industrial Robot Arm"}]
2e:["$","p","p-8",{"children":[["$","strong","strong-0",{"children":"Event"}],": Development of the first electrically-driven, 6-DOF robot arm with servo feedback control.",["$","br","br-0",{}],"\n",["$","strong","strong-1",{"children":"Advancement"}],": Moves the industry beyond hydraulics, enabling much finer control and lower maintenance.",["$","br","br-1",{}],"\n",["$","strong","strong-2",{"children":"Impact"}],": Leads to widespread deployment of welding and assembly robots in automotive manufacturing by KUKA, ABB, and FANUC."]}]
2f:["$","hr","hr-2",{}]
30:["$","h2","h2-3",{"children":"3. Digital Control & Early Networking (1980 - 1990)"}]
31:["$","h3","h3-8",{"children":"1983: SCADA Systems Emerge"}]
32:["$","p","p-9",{"children":[["$","strong","strong-0",{"children":"Event"}],": Supervisory Control and Data Acquisition (SCADA) systems become widespread for centralized monitoring.",["$","br","br-0",{}],"\n",["$","strong","strong-1",{"children":"Architecture"}],": Central control centers communicating via telecommunications to Remote Terminal Units (RTUs) at the edge.",["$","br","br-1",{}],"\n",["$","strong","strong-2",{"children":"Impact"}],": Enables the remote operation of geographically massive critical infrastructure (power grids, water treatment, pipelines)."]}]
