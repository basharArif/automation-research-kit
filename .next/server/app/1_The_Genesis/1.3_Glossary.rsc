3a:["$","p","p-30",{"children":[["$","strong","strong-0",{"children":"FMEA (Failure Mode and Effects Analysis)"}],": Risk assessment method identifying failure modes, causes, effects; basis for safety design."]}]
3b:["$","p","p-31",{"children":[["$","strong","strong-0",{"children":"Formal Verification"}],": Mathematical proof that system satisfies specification for ALL possible inputs; contrasts with testing (finite samples). Challenging for complex systems."]}]
3c:["$","p","p-32",{"children":[["$","strong","strong-0",{"children":"Frequency Domain"}],": Analysis using sinusoidal inputs and studying output relationships via Fourier/Laplace transforms. Complements time-domain analysis."]}]
3d:["$","hr","hr-6",{}]
3e:["$","h2","h2-6",{"children":"G"}]
3f:["$","p","p-33",{"children":[["$","strong","strong-0",{"children":"Gazebo"}],": Open-source 3D robot simulation engine; integrates with ROS/ROS2 for rapid prototyping."]}]
40:["$","p","p-34",{"children":[["$","strong","strong-0",{"children":"Gradient Descent"}],": Optimization technique iteratively updating parameters to minimize loss; foundation of deep learning training."]}]
41:["$","p","p-35",{"children":[["$","strong","strong-0",{"children":"Gripper"}],": End-effector for grasping; parallel-jaw (simple), under-actuated (compliant), humanoid (complex dexterity)."]}]
42:["$","hr","hr-7",{}]
43:["$","h2","h2-7",{"children":"H"}]
44:["$","p","p-36",{"children":[["$","strong","strong-0",{"children":"Hardware-in-the-Loop (HIL)"}],": Simulation testing involving actual hardware controller interacting with simulated plant; validates control implementation."]}]
45:["$","p","p-37",{"children":[["$","strong","strong-0",{"children":"Homeostasis"}],": Biological principle maintaining internal equilibrium despite external perturbations through feedback loops; inspires automation design."]}]
46:["$","p","p-38",{"children":[["$","strong","strong-0",{"children":"Human-in-the-Loop"}],": Design where human provides oversight, intervention, or learning to automated system; balances autonomy and control."]}]
47:["$","hr","hr-8",{}]
48:["$","h2","h2-8",{"children":"I"}]
49:["$","p","p-39",{"children":[["$","strong","strong-0",{"children":"IEC 61508"}],": Functional safety standard for electrical/electronic systems; defines Safety Integrity Levels (SIL 1-4) based on risk."]}]
4a:["$","p","p-40",{"children":[["$","strong","strong-0",{"children":"IEC 61131-3"}],": International standard for PLC programming languages (ladder logic, structured text, function blocks)."]}]
4b:["$","p","p-41",{"children":[["$","strong","strong-0",{"children":"IEC 62443"}],": Industrial cybersecurity standard; defines security levels (SL) 1-4 for automation systems."]}]
4c:["$","p","p-42",{"children":[["$","strong","strong-0",{"children":"IIoT (Industrial Internet of Things)"}],": Connected sensors/devices in manufacturing; enables predictive maintenance, optimization, digital twins."]}]
4d:["$","p","p-43",{"children":[["$","strong","strong-0",{"children":"Imitation Learning"}],": Learning from demonstrations rather than reward signals; faster convergence but limited to demonstrated behaviors."]}]
4e:["$","p","p-44",{"children":[["$","strong","strong-0",{"children":"Integral Windup"}],": PID control problem; integral term accumulates large error when output saturated, causing overshoot. Mitigated via anti-windup schemes."]}]
4f:["$","p","p-45",{"children":[["$","strong","strong-0",{"children":"Inverse Reinforcement Learning"}],": Learning reward function from expert demonstrations; enables policy inference without explicit reward."]}]
50:["$","p","p-46",{"children":[["$","strong","strong-0",{"children":"ISA-95"}],": Enterprise-to-manufacturing integration standard; defines levels 0 (process) through 5 (enterprise)."]}]
51:["$","p","p-47",{"children":[["$","strong","strong-0",{"children":"ISO 26262"}],": Functional safety standard for automotive systems; ASIL ratings (A-D) based on severity, exposure, controllability."]}]
52:["$","p","p-48",{"children":[["$","strong","strong-0",{"children":"ISO 10218"}],": Industrial robot safety standard; covers robot design, operation, programming, maintenance."]}]
53:["$","hr","hr-9",{}]
54:["$","h2","h2-9",{"children":"J"}]
55:["$","p","p-49",{"children":[["$","strong","strong-0",{"children":"Jacobian Matrix"}],": Maps joint velocities to end-effector velocities; (v = J(\\theta) \\dot{\\theta}). Singularities occur when rank deficient."]}]
56:["$","p","p-50",{"children":[["$","strong","strong-0",{"children":"Jerk"}],": Third derivative of position (acceleration change rate); smooth trajectories minimize jerk for comfort and actuator wear."]}]
57:["$","hr","hr-10",{}]
58:["$","h2","h2-10",{"children":"K"}]
59:["$","p","p-51",{"children":[["$","strong","strong-0",{"children":"Kinematics"}],": Study of motion without considering forces; forward kinematics (joint angles → end-effector pose), inverse (pose → angles)."]}]
5a:["$","p","p-52",{"children":[["$","strong","strong-0",{"children":"Knowledge Distillation"}],": Training small \"student\" neural network to mimic large \"teacher\"; enables edge deployment with performance retention."]}]
5b:["$","hr","hr-11",{}]
5c:["$","h2","h2-11",{"children":"L"}]
5d:["$","p","p-53",{"children":[["$","strong","strong-0",{"children":"Lag (Phase Lag)"}],": Phase shift in output relative to sinusoidal input; destabilizing for control; compensated via lead networks."]}]
5e:["$","p","p-54",{"children":[["$","strong","strong-0",{"children":"Laplace Transform"}],": Mathematical tool converting differential equations to algebraic form; foundation of classical control theory. (\\mathcal{L}(f(t)) = F(s) = \\int_0^\\infty f(t)e^{-st}dt)"]}]
5f:["$","p","p-55",{"children":[["$","strong","strong-0",{"children":"Lead Network"}],": Compensator increasing phase margin; improves stability and response speed."]}]
60:["$","p","p-56",{"children":[["$","strong","strong-0",{"children":"Learning Rate"}],": Hyperparameter controlling step size in gradient descent; too high → divergence, too low → slow convergence."]}]
61:["$","p","p-57",{"children":[["$","strong","strong-0",{"children":"LiDAR (Light Detection and Ranging)"}],": Laser-based sensor generating 3D point clouds; robust in various lighting, weather; used in autonomous vehicles, robots."]}]
62:["$","p","p-58",{"children":[["$","strong","strong-0",{"children":"Linear Quadratic Regulator (LQR)"}],": Optimal control minimizing quadratic cost (J = \\int(x^T Qx + u^T Ru)dt); analytically solved via Riccati equation."]}]
63:["$","p","p-59",{"children":[["$","strong","strong-0",{"children":"Loop Closure"}],": SLAM concept; detecting when robot revisits previously mapped location, correcting accumulated drift."]}]
64:["$","p","p-60",{"children":[["$","strong","strong-0",{"children":"Lyapunov Function"}],": Mathematical function proving stability; if (V(x) > 0) for all (x \\neq 0) and (\\dot{V}(x) < 0), system converges to origin."]}]
65:["$","hr","hr-12",{}]
66:["$","h2","h2-12",{"children":"M"}]
67:["$","p","p-61",{"children":[["$","strong","strong-0",{"children":"Machine Learning"}],": Field where systems learn patterns from data without explicit programming; includes supervised, unsupervised, reinforcement learning."]}]
68:["$","p","p-62",{"children":[["$","strong","strong-0",{"children":"MQTT (Message Queuing Telemetry Transport)"}],": Lightweight pub-sub protocol for IoT/cloud connectivity; complements OPC UA for cloud integration."]}]
69:["$","p","p-63",{"children":[["$","strong","strong-0",{"children":"Model Predictive Control (MPC)"}],": Optimal control predicting next N steps, solving optimization problem, implementing first action, replanning. Robust, handles constraints."]}]
6a:["$","p","p-64",{"children":[["$","strong","strong-0",{"children":"Modulation (PWM)"}],": Pulse-width modulation encodes analog value as duty cycle of switching signal; widely used for motor speed control."]}]
6b:["$","p","p-65",{"children":[["$","strong","strong-0",{"children":"Motor"}],": Electrical actuator converting electrical energy to mechanical motion; types: DC, AC induction, stepper, brushless (BLDC)."]}]
6c:["$","p","p-66",{"children":[["$","strong","strong-0",{"children":"MuJoCo"}],": Open-source physics engine; accurate simulation, differentiable enabling gradient-based learning; increasingly popular for RL robotics."]}]
6d:["$","p","p-67",{"children":[["$","strong","strong-0",{"children":"Multitasking (RTOS)"}],": Real-time operating system supporting multiple concurrent tasks; essential for complex automation."]}]
6e:["$","hr","hr-13",{}]
6f:["$","h2","h2-13",{"children":"N"}]
70:["$","p","p-68",{"children":[["$","strong","strong-0",{"children":"Neural Network"}],": Biologically-inspired computational model; nodes (neurons) connected via weighted edges; trained to approximate functions."]}]
71:["$","p","p-69",{"children":[["$","strong","strong-0",{"children":"Noise"}],": Undesired signal degrading measurements; control must be robust to noise (Kalman filter, low-pass filtering)."]}]
72:["$","p","p-70",{"children":[["$","strong","strong-0",{"children":"Nyquist Plot"}],": Frequency domain stability criterion; plots complex transfer function G(jω); encircles -1 point ⟺ system unstable."]}]
73:["$","hr","hr-14",{}]
74:["$","h2","h2-14",{"children":"O"}]
75:["$","p","p-71",{"children":[["$","strong","strong-0",{"children":"Observability"}],": Can system state be inferred from measurements? Rank condition: (rank([C; CA; ...; CA^{n-1}]) = n)."]}]
76:["$","p","p-72",{"children":[["$","strong","strong-0",{"children":"Observer"}],": State estimator inferring unmeasured states from measurements; dual to controller."]}]
77:["$","p","p-73",{"children":[["$","strong","strong-0",{"children":"OPC UA (OLE for Process Control Unified Architecture)"}],": Industrial interoperability standard; semantic data models, security, cross-platform. Key enabler of Industry 4.0."]}]
78:["$","p","p-74",{"children":[["$","strong","strong-0",{"children":"Open-Loop Control"}],": No feedback; control signal determined by reference only. Example: timed heating. Susceptible to disturbances."]}]
79:["$","p","p-75",{"children":[["$","strong","strong-0",{"children":"Open Source"}],": Software with publicly available source code; often MIT, Apache, GPL licenses. Enables community contributions, transparency."]}]
7a:["$","p","p-76",{"children":[["$","strong","strong-0",{"children":"Overshoot"}],": Transient response exceeding steady-state value; tuning trade-off with settling time."]}]
7b:["$","hr","hr-15",{}]
7c:["$","h2","h2-15",{"children":"P"}]
7d:["$","p","p-77",{"children":[["$","strong","strong-0",{"children":"PID Controller"}],": Ubiquitous feedback controller combining Proportional, Integral, Derivative terms. (u = K_p e + K_i \\int e + K_d \\dot{e}). Dominates 95% of industrial control."]}]
7e:["$","p","p-78",{"children":[["$","strong","strong-0",{"children":"Plant"}],": System being controlled; in control theory, (\\dot{x} = Ax + Bu)."]}]
7f:["$","p","p-79",{"children":[["$","strong","strong-0",{"children":"Policy (RL)"}],": Function mapping state to action; deterministic (\\pi(s) = a) or stochastic (\\pi(a|s)) (probability distribution)."]}]
80:["$","p","p-80",{"children":[["$","strong","strong-0",{"children":"PPO (Proximal Policy Optimization)"}],": State-of-the-art RL algorithm; policy gradient method with clipped objective preventing excessive updates. Sample-efficient, stable."]}]
81:["$","p","p-81",{"children":[["$","strong","strong-0",{"children":"Proportional Control"}],": Output proportional to error: (u = K_p e); simple, no overshoot if tuned conservatively, steady-state error if integral term absent."]}]
82:["$","p","p-82",{"children":[["$","strong","strong-0",{"children":"Pruning"}],": Removing low-weight neural network connections; reduces parameters/computation while maintaining accuracy."]}]
83:["$","hr","hr-16",{}]
84:["$","h2","h2-16",{"children":"Q"}]
85:["$","p","p-83",{"children":[["$","strong","strong-0",{"children":"Quantization"}],": Converting continuous values to discrete (or lower precision). INT8 quantization: 75% memory reduction, 4x speedup vs FP32."]}]
86:["$","p","p-84",{"children":[["$","strong","strong-0",{"children":"QoS (Quality of Service)"}],": ROS2 parameter; trade-off between reliability (guaranteed delivery) and low latency."]}]
87:["$","hr","hr-17",{}]
88:["$","h2","h2-17",{"children":"R"}]
89:["$","p","p-85",{"children":[["$","strong","strong-0",{"children":"Reality Gap"}],": Sim2real transfer problem; policy trained in simulation degrades on real hardware due to sensing/dynamics mismatch."]}]
8a:["$","p","p-86",{"children":[["$","strong","strong-0",{"children":"Reference Tracking"}],": Control objective: follow desired trajectory/setpoint. Contrasts with regulation (maintain at setpoint)."]}]
8b:["$","p","p-87",{"children":[["$","strong","strong-0",{"children":"Reinforcement Learning (RL)"}],": Learning from interaction; agent receives reward signal, optimizes accumulated reward over time. Model-free learning."]}]
8c:["$","p","p-88",{"children":[["$","strong","strong-0",{"children":"Reliability"}],": System ability to function without failure over time; measured via MTBF (mean time between failures)."]}]
8d:["$","p","p-89",{"children":[["$","strong","strong-0",{"children":"ROS/ROS2 (Robot Operating System)"}],": Open-source middleware for robotics; pub-sub communication, 3000+ packages, de facto research standard."]}]
8e:["$","p","p-90",{"children":[["$","strong","strong-0",{"children":"RPA (Robotic Process Automation)"}],": Software bots automating repetitive digital tasks (data entry, invoice processing); 53% enterprise adoption 2024."]}]
8f:["$","p","p-91",{"children":[["$","strong","strong-0",{"children":"RTOS (Real-Time Operating System)"}],": OS guaranteeing worst-case latencies; essential for control timing guarantees."]}]
90:["$","p","p-92",{"children":[["$","strong","strong-0",{"children":"RRT (Rapidly-Exploring Random Tree)"}],": Probabilistically complete motion planning algorithm; fast, handles high-dimensional spaces, asymptotically optimal with RRT* variant."]}]
91:["$","hr","hr-18",{}]
92:["$","h2","h2-18",{"children":"S"}]
93:["$","p","p-93",{"children":[["$","strong","strong-0",{"children":"SCADA (Supervisory Control and Data Acquisition)"}],": Centralized monitoring of geographically distributed automation systems; operator supervises remote facilities."]}]
94:["$","p","p-94",{"children":[["$","strong","strong-0",{"children":"Sensor Fusion"}],": Combining multiple noisy measurements into state estimate; Kalman filter optimal for linear systems, particle filters for nonlinear."]}]
95:["$","p","p-95",{"children":[["$","strong","strong-0",{"children":"Settling Time"}],": Time for response to reach steady state within tolerance band; inversely related to control bandwidth."]}]
96:["$","p","p-96",{"children":[["$","strong","strong-0",{"children":"Sim2Real Transfer"}],": Training controller in simulation, deploying on real system; domain randomization reduces reality gap to <3%."]}]
97:["$","p","p-97",{"children":[["$","strong","strong-0",{"children":"Simulation (Control)"}],": Mathematical model predicting system behavior; enables design validation, tuning, operator training without risking real equipment."]}]
98:["$","p","p-98",{"children":[["$","strong","strong-0",{"children":"SLAM (Simultaneous Localization and Mapping)"}],": Robot inference of own pose AND map of environment from sensor data; enables autonomous navigation."]}]
99:["$","p","p-99",{"children":[["$","strong","strong-0",{"children":"Soft Actor-Critic (SAC)"}],": Deep RL algorithm maximizing reward + entropy (exploration); excellent sample efficiency, state-of-the-art for continuous control."]}]
9a:["$","p","p-100",{"children":[["$","strong","strong-0",{"children":"Stability"}],": Property of system; small perturbations don't cause large responses; asymptotic stability → trajectories converge to equilibrium."]}]
9b:["$","p","p-101",{"children":[["$","strong","strong-0",{"children":"State (Control)"}],": System variables determining future behavior; e.g., position, velocity, temperature. State-space representation: (\\dot{x} = Ax + Bu)."]}]
9c:["$","p","p-102",{"children":[["$","strong","strong-0",{"children":"State Machine"}],": Discrete system with finite states and transitions; FSM fundamental to PLC logic and embedded systems."]}]
9d:["$","p","p-103",{"children":[["$","strong","strong-0",{"children":"State-Space"}],": Mathematical representation using state vector (x(t)) rather than differential equations; enables matrix algebra, eigenvalue analysis."]}]
9e:["$","p","p-104",{"children":[["$","strong","strong-0",{"children":"Steady-State Error"}],": Difference between reference and actual output after transients decay; eliminated via integral action."]}]
9f:["$","hr","hr-19",{}]
a0:["$","h2","h2-19",{"children":"T"}]
a1:["$","p","p-105",{"children":[["$","strong","strong-0",{"children":"Task Space (Cartesian Space)"}],": Robot coordinates (3D position + orientation) contrasted with joint space (DOF angles)."]}]
a2:["$","p","p-106",{"children":[["$","strong","strong-0",{"children":"Temporal Logic"}],": Formal language expressing system properties over time; LTL (Linear Temporal Logic), MTL (Metric Temporal Logic)."]}]
a3:["$","p","p-107",{"children":[["$","strong","strong-0",{"children":"Time Constant"}],": Characteristic time for system response; (\\tau) in first-order: (y(t) = y_{ss}(1 - e^{-t/\\tau}))."]}]
a4:["$","p","p-108",{"children":[["$","strong","strong-0",{"children":"Transfer Function"}],": Ratio of output to input in Laplace domain; (G(s) = Y(s)/U(s)). Captures system behavior for control design."]}]
a5:["$","p","p-109",{"children":[["$","strong","strong-0",{"children":"Trajectory"}],": Path through state/configuration space over time; includes velocities, accelerations (contrasts with path, which is geometric)."]}]
a6:["$","p","p-110",{"children":[["$","strong","strong-0",{"children":"Transient Response"}],": System behavior before reaching steady state; characterized by overshoot, settling time, rise time."]}]
a7:["$","hr","hr-20",{}]
a8:["$","h2","h2-20",{"children":"U"}]
a9:["$","p","p-111",{"children":[["$","strong","strong-0",{"children":"Uncertainty (Robustness)"}],": Model mismatch, parameter variation, disturbances. Robust control maintains stability despite uncertainty bounds."]}]
aa:["$","hr","hr-21",{}]
ab:["$","h2","h2-21",{"children":"V"}]
ac:["$","p","p-112",{"children":[["$","strong","strong-0",{"children":"Vision-Based Control"}],": Using camera feedback for control; enables manipulation, navigation; challenges: latency, occlusion."]}]
ad:["$","hr","hr-22",{}]
ae:["$","h2","h2-22",{"children":"W"}]
af:["$","p","p-113",{"children":[["$","strong","strong-0",{"children":"Workspace"}],": Reachable region for robot end-effector; bounded by joint limits, singular configurations."]}]
b0:["$","hr","hr-23",{}]
b1:["$","h2","h2-23",{"children":"X-Z"}]
b2:["$","p","p-114",{"children":[["$","strong","strong-0",{"children":"YOLO (You Only Look Once)"}],": Single-stage object detection neural network; real-time speed (~50 FPS), moderate accuracy (~85-90% mAP)."]}]
b3:["$","p","p-115",{"children":[["$","strong","strong-0",{"children":"Ziegler-Nichols Tuning"}],": PID tuning method inducing oscillation at stability boundary, deriving gain formulas; practical, heuristic."]}]
b4:["$","hr","hr-24",{}]
b5:["$","h2","h2-24",{"children":"Cross-References & Relationships"}]
b6:["$","h3","h3-0",{"children":"Control Concepts"}]
b7:["$","ul","ul-0",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Open-Loop"}]," ← → ",["$","strong","strong-1",{"children":"Closed-Loop"}]]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Time Domain"}]," ← → ",["$","strong","strong-1",{"children":"Frequency Domain"}]]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Proportional"}]," → ",["$","strong","strong-1",{"children":"Integral"}]," → ",["$","strong","strong-2",{"children":"Derivative"}]," (PID)"]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Stability"}]," ← (via Lyapunov) → ",["$","strong","strong-1",{"children":"Robustness"}]]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Control Theory"}]," ← (rooted in) → ",["$","strong","strong-1",{"children":"Cybernetics"}]]}],"\n"]}]
b8:["$","h3","h3-1",{"children":"Automation Hierarchy"}]
b9:["$","ol","ol-0",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Sensing"}]," (sensors, perception, state estimation)"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Decision"}]," (control, planning, learning)"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Actuation"}]," (motors, pneumatics, hydraulics)"]}],"\n"]}]
ba:["$","h3","h3-2",{"children":"Standards & Compliance"}]
bb:["$","ul","ul-1",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"IEC 61508"}]," (safety) ⊃ ",["$","strong","strong-1",{"children":"ISO 26262"}]," (automotive) ⊃ ",["$","strong","strong-2",{"children":"ISO 10218"}]," (robots)"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"ISA-95"}]," (enterprise integration)"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"IEC 62443"}]," (cybersecurity)"]}],"\n"]}]
bc:["$","h3","h3-3",{"children":"Modern Automation Stack"}]
bd:["$","ul","ul-2",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Perception"}],": Sensors → Sensor Fusion → State Estimate"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Planning"}],": Localization → Mapping → Path Planning → Trajectory Optimization"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Control"}],": PID (classical) | MPC (modern) | RL (learning-based)"]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Integration"}],": ROS2, SCADA, OPC UA, Kubernetes"]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Safety"}],": Formal Verification, CBF, Shielding"]}],"\n"]}]
