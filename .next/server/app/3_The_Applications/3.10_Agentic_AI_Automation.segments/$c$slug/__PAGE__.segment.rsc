0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"markdown-container","children":[["$","h1","h1-0",{"children":"Sector Brief: Agentic AI Automation"}],"\n",["$","p","p-0",{"children":[["$","strong","strong-0",{"children":"Version"}],": 1.0 | ",["$","strong","strong-1",{"children":"Last Updated"}],": 2026-05-07",["$","br","br-0",{}],"\n",["$","strong","strong-2",{"children":"Scope"}],": Autonomous AI agents, computer-use, LLM-based workflows, orchestration, enterprise deployments"]}],"\n",["$","hr","hr-0",{}],"\n",["$","h2","h2-0",{"children":"See Also"}],"\n",["$","ul","ul-0",{"children":["\n",["$","li","li-0",{"children":[["$","a","a-0",{"href":"3.9_AI_Driven_Automation.md","children":"AI-Driven Automation"}]," — foundation models, core AI technologies"]}],"\n",["$","li","li-1",{"children":[["$","a","a-0",{"href":"3.5_Robotic_Process_Automation.md","children":"RPA Sector Brief"}]," — traditional and hyperautomation context"]}],"\n",["$","li","li-2",{"children":[["$","a","a-0",{"href":"../../4_The_Horizons/4.1_Research_Frontiers.md","children":"Research Frontiers §8"}]," — foundation models as open research problem"]}],"\n"]}],"\n",["$","hr","hr-1",{}],"\n",["$","h2","h2-1",{"children":"1. Overview"}],"\n",["$","p","p-1",{"children":[["$","strong","strong-0",{"children":"Agentic AI automation"}]," refers to AI systems that autonomously plan, decide, and execute multi-step tasks across software environments with minimal human intervention. Unlike traditional RPA (which follows deterministic scripts) or narrow AI (which classifies/predicts), agents:"]}],"\n",["$","ol","ol-0",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Perceive"}]," their environment (web browsers, APIs, files, UIs, emails)"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Plan"}]," a sequence of actions to achieve a goal"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Execute"}]," those actions using available tools"]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Reflect"}]," on results and adjust the plan when unexpected things happen"]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Complete"}]," the task or escalate to a human when genuinely stuck"]}],"\n"]}],"\n",["$","p","p-2",{"children":"This is the convergence of LLMs' reasoning capability with RPA's execution capability—producing systems that handle ambiguity, exceptions, and novel situations that break deterministic scripts."}],"\n",["$","p","p-3",{"children":[["$","strong","strong-0",{"children":"Market emergence"}],": Agentic AI entered mainstream enterprise deployments in 2024–2025. Gartner identifies it as the #1 technology trend for 2025–2026."]}],"\n",["$","hr","hr-2",{}],"\n",["$","h2","h2-2",{"children":"2. What Makes a System \"Agentic\""}],"\n",["$","h3","h3-0",{"children":"2.1 Key Properties"}],"\n",["$","table","table-0",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"Property"}],["$","th","th-1",{"children":"Traditional RPA"}],["$","th","th-2",{"children":"AI Agent"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Task specification"}]}],["$","td","td-1",{"children":"Exact step-by-step script"}],["$","td","td-2",{"children":"High-level goal"}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Exception handling"}]}],["$","td","td-1",{"children":"Throw exception → human"}],["$","td","td-2",{"children":"Reason and adapt"}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Planning"}]}],["$","td","td-1",{"children":"Fixed workflow"}],["$","td","td-2",{"children":"Dynamic, replanned each step"}]]}],["$","tr","tr-3",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Tools used"}]}],["$","td","td-1",{"children":"Pre-configured UI actions"}],["$","td","td-2",{"children":"Browser, APIs, code execution, file I/O"}]]}],["$","tr","tr-4",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Memory"}]}],"$L2","$L3"]}],"$L4","$L5"]}]]}],"\n","$L6","\n","$L7","\n","$L8","\n","$L9","\n","$La","\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21","\n","$L22","\n","$L23","\n","$L24","\n","$L25","\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a","\n","$L2b","\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f"]}],null,"$L50"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"sFzo4LKMJghR7e79YRpfU"}
