13:["$","ul","ul-4",{"children":["\n",["$","li","li-0",{"children":"Claude 3.5/3.7 Sonnet with computer-use capability: sees a screenshot, identifies elements, issues mouse/keyboard commands."}],"\n",["$","li","li-1",{"children":"Available via API (AWS Bedrock, Anthropic API)."}],"\n",["$","li","li-2",{"children":"Benchmark (OSWorld): 14.9% task completion (first release, 2024) → improved substantially in subsequent versions."}],"\n",["$","li","li-3",{"children":"Enterprise use: IT operations automation, customer portal navigation."}],"\n"]}]
