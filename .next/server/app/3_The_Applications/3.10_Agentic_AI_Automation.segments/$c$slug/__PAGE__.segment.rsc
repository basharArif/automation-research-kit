2e:["$","ul","ul-16",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Code generation + testing"}],": Agent writes code from specification, runs tests, debugs failing tests, iterates until tests pass."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"GitHub Copilot Workspace (2025)"}],": Given a GitHub issue, agent proposes plan, writes code, creates PR."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Devin (Cognition, 2024)"}],": \"AI software engineer\" — scored 13.86% on SWEbench (resolving real GitHub issues) without human help. First demonstration that an AI agent can resolve nontrivial software engineering tasks end-to-end."]}],"\n"]}]
