11:["$","ul","ul-3",{"children":["\n",["$","li","li-0",{"children":"OpenAI's computer-use agent: navigates the web, fills forms, makes reservations, purchases items on behalf of users."}],"\n",["$","li","li-1",{"children":"Uses CUA (Computer Use Agent) model fine-tuned for UI interaction."}],"\n",["$","li","li-2",{"children":"Integrated into ChatGPT Pro ($200/month tier); API access for enterprises."}],"\n",["$","li","li-3",{"children":"Demonstrated tasks: book restaurant reservations, file insurance claims, submit government forms."}],"\n"]}]
