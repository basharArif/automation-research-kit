26:["$","ul","ul-12",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Incident response"}],": Agent monitors alerts, queries runbooks, executes remediation steps (restart service, scale resources, rollback deployment), files incident tickets, notifies stakeholders."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Change management"}],": Agent reviews proposed infrastructure changes against policy, runs pre-flight checks, executes changes in maintenance windows, validates success."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Example"}],": PagerDuty + LLM agent: Mean Time to Resolution (MTTR) reduced 40% in pilot deployments [PagerDuty, 2025]."]}],"\n"]}]
27:["$","h3","h3-9",{"children":"4.2 Finance and Procurement"}]
28:["$","ul","ul-13",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Procurement automation"}],": Agent receives purchase request → checks budget → finds approved vendors → solicits quotes → evaluates against policy → creates PO → routes for approval → notifies requestor."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Month-end close"}],": Agent extracts data from ERP, performs reconciliation, flags anomalies, generates explanations, sends to controller for review."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Expense processing"}],": Agent reviews expense reports, checks policy compliance, requests missing receipts via email, approves or escalates."]}],"\n"]}]
29:["$","h3","h3-10",{"children":"4.3 Customer Service"}]
2a:["$","ul","ul-14",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Tier 1 resolution"}],": Agent reads customer email, queries CRM and order systems, takes resolution action (process refund, update order), responds to customer — without human involvement for standard cases."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Escalation intelligence"}],": When agent cannot resolve, it prepares a complete case summary with attempted solutions before handing to human agent."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Reported impact"}],": Klarna (2024) deployed AI agent handling 2.3M customer service chats, equivalent to 700 FTEs, 82% customer satisfaction (equal to human agents)."]}],"\n"]}]
2b:["$","h3","h3-11",{"children":"4.4 Research and Analysis"}]
2c:["$","ul","ul-15",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Competitive intelligence"}],": Agent browses company websites, news, patent filings, earnings transcripts → synthesizes a structured competitive analysis."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Literature review"}],": Agent searches academic databases (Semantic Scholar, PubMed, arXiv), reads papers, extracts relevant findings, synthesizes into a structured review."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Due diligence"}],": Agent reviews documents, checks public records, validates financial statements, identifies red flags."]}],"\n"]}]
