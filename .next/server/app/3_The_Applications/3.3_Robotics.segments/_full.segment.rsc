en":"First Generation (1960s-1980s)"}],": Simple programmable manipulators for repetitive tasks"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Second Generation (1990s-2000s)"}],": Sensor-equipped robots with basic perception"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Third Generation (2000s-2015)"}],": Networked robots with ROS-based software"]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Fourth Generation (2015-Present)"}],": AI-driven robots with deep learning capabilities"]}],"\n"]}],"\n",["$","h2","h2-2",{"children":"2. Core Components of a Robotic System"}],"\n",["$","p","p-3",{"children":"A typical robotic system consists of several interconnected subsystems:"}],"\n",["$","h3","h3-0",{"children":"2.1 Sensors (Perception Subsystem)"}],"\n",["$","ul","ul-2",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Vision Sensors:"}]," Cameras, stereo cameras, RGB-D sensors (e.g., Intel RealSense, Microsoft Kinect)"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Range Sensors:"}]," LiDAR, ultrasonic sensors, laser range finders"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Inertial Sensors:"}]," IMUs (Inertial Measurement Units), accelerometers, gyroscopes"]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Force/Torque Sensors:"}]," For precise manipulation and haptic feedback"]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Tactile Sensors:"}]," For fine manipulation and object recognition"]}],"\n"]}],"\n",["$","h3","h3-1",{"children":"2.2 Actuators (Action Subsystem)"}],"\n",["$","ul","ul-3",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Electric Motors:"}]," Servo motors, stepper motors (precise control)"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Hydraulic Actuators:"}]," High force applications (construction, heavy industry)"]}],"\n","$L26","\n","$L27","\n","$L28","\n"]}],"\n","$L29","\n","$L2a","\n","$L2b","\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n","$L54","\n","$L55","\n","$L56","\n","$L57","\n","$L58","\n","$L59","\n","$L5a","\n","$L5b","\n","$L5c","\n","$L5d","\n","$L5e","\n","$L5f","\n","$L60","\n","$L61","\n","$L62","\n","$L63","\n","$L64","\n","$L65","\n","$L66","\n","$L67","\n","$L68","\n","$L69","\n","$L6a","\n","$L6b","\n","$L6c","\n","$L6d","\n","$L6e","\n","$L6f","\n","$L70","\n","$L71","\n","$L72","\n","$L73","\n","$L74","\n","$L75","\n","$L76","\n","$L77","\n","$L78","\n","$L79","\n","$L7a","\n","$L7b","\n","$L7c"]}]
