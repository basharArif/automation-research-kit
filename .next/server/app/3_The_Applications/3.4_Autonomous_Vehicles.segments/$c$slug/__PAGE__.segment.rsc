27:["$","table","table-1",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"ASIL"}],["$","th","th-1",{"children":"Severity"}],["$","th","th-2",{"children":"Exposure"}],["$","th","th-3",{"children":"Controllability"}],["$","th","th-4",{"children":"Example Application"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"A"}]}],["$","td","td-1",{"children":"Low"}],["$","td","td-2",{"children":"Low"}],["$","td","td-3",{"children":"Mostly controllable"}],["$","td","td-4",{"children":"Comfort systems"}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"B"}]}],["$","td","td-1",{"children":"Moderate"}],["$","td","td-2",{"children":"Moderate"}],["$","td","td-3",{"children":"Normally controllable"}],["$","td","td-4",{"children":"Anti-lock braking"}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"C"}]}],["$","td","td-1",{"children":"High"}],["$","td","td-2",{"children":"Moderate"}],["$","td","td-3",{"children":"Difficult to control"}],["$","td","td-4",{"children":"Power steering"}]]}],["$","tr","tr-3",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"D"}]}],["$","td","td-1",{"children":"Catastrophic"}],["$","td","td-2",{"children":"High"}],["$","td","td-3",{"children":"Uncontrollable"}],["$","td","td-4",{"children":"Autonomous braking, steering"}]]}]]}]]}]
28:["$","p","p-18",{"children":["AV perception, planning, and actuation systems typically require ",["$","strong","strong-0",{"children":"ASIL-D"}]," certification—the most stringent level. This requires hardware/software decomposition, fail-safe states, diagnostic coverage >99%."]}]
