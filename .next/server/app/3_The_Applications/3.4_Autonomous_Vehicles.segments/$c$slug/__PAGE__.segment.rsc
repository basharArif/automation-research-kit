0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"markdown-container","children":[["$","h1","h1-0",{"children":"Sector Brief: Autonomous Vehicles"}],"\n",["$","p","p-0",{"children":[["$","strong","strong-0",{"children":"Version"}],": 2.0 | ",["$","strong","strong-1",{"children":"Last Updated"}],": 2026-05-07",["$","br","br-0",{}],"\n",["$","strong","strong-2",{"children":"Scope"}],": SAE autonomy levels, sensor systems, perception stack, safety standards, deployment status, regulation"]}],"\n",["$","hr","hr-0",{}],"\n",["$","h2","h2-0",{"children":"See Also"}],"\n",["$","ul","ul-0",{"children":["\n",["$","li","li-0",{"children":[["$","a","a-0",{"href":"3.1_Industrial_Automation.md","children":"Industrial Automation"}]," — cybersecurity (IEC 62443) relevant to connected vehicles"]}],"\n",["$","li","li-1",{"children":[["$","a","a-0",{"href":"3.9_AI_Driven_Automation.md","children":"AI-Driven Automation"}]," — foundation models and perception AI"]}],"\n",["$","li","li-2",{"children":[["$","a","a-0",{"href":"../../4_The_Horizons/4.1_Research_Frontiers.md","children":"Research Frontiers"}]," — open problems in AV safety"]}],"\n",["$","li","li-3",{"children":[["$","a","a-0",{"href":"../../4_The_Horizons/4.2_Ethics_and_Society.md","children":"Ethics and Society"}]," — liability, trolley problem, regulatory frameworks"]}],"\n"]}],"\n",["$","hr","hr-1",{}],"\n",["$","h2","h2-1",{"children":"1. Overview"}],"\n",["$","p","p-1",{"children":"Autonomous vehicles (AVs) are ground vehicles capable of sensing their environment, planning trajectories, and executing motion with reduced or eliminated human input. The technology integrates advances from robotics, computer vision, machine learning, high-precision mapping, and communication systems into a safety-critical real-time system."}],"\n",["$","p","p-2",{"children":[["$","strong","strong-0",{"children":"Market scale (2025)"}],":"]}],"\n",["$","ul","ul-1",{"children":["\n",["$","li","li-0",{"children":["Global AV market: ",["$","strong","strong-0",{"children":"$$54B"}]," (2025), projected $556B by 2035 [Allied Market Research, 2025]"]}],"\n",["$","li","li-1",{"children":"Robotaxi operations active in: San Francisco, Phoenix, Los Angeles, Austin, Atlanta, Miami (Waymo), select Chinese cities (Baidu Apollo)"}],"\n",["$","li","li-2",{"children":"Autonomous trucking deployments: Texas, Arizona freight corridors (Aurora, Kodiak)"}],"\n"]}],"\n",["$","hr","hr-2",{}],"\n",["$","h2","h2-2",{"children":"2. SAE Levels of Driving Automation (J3016)"}],"\n",["$","p","p-3",{"children":"The Society of Automotive Engineers (SAE) defines six discrete automation levels, updated in SAE J3016:2021:"}],"\n",["$","table","table-0",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"Level"}],["$","th","th-1",{"children":"Name"}],["$","th","th-2",{"children":"Human Role"}],["$","th","th-3",{"children":"System Role"}],["$","th","th-4",{"children":"Commercial Examples (2025)"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"L0"}]}],["$","td","td-1",{"children":"No Automation"}],["$","td","td-2",{"children":"Full driving"}],["$","td","td-3",{"children":"Warnings only"}],["$","td","td-4",{"children":"Most vehicles"}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"L1"}]}],["$","td","td-1",{"children":"Driver Assistance"}],["$","td","td-2",{"children":"Must monitor + control"}],["$","td","td-3",{"children":"Steer OR accelerate/brake"}],["$","td","td-4",{"children":"Toyota Safety Sense, Honda Sensing"}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"L2"}]}],["$","td","td-1",{"children":"Partial Automation"}],["$","td","td-2",{"children":"Must monitor constantly"}],["$","td","td-3",{"children":"Steer AND accelerate/brake"}],["$","td","td-4",{"children":"Tesla