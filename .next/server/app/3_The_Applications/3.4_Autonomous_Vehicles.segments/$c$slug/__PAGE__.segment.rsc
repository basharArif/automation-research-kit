2a:["$","p","p-19",{"children":["ISO 26262 covers faults (hardware failures). ",["$","strong","strong-0",{"children":"SOTIF"}]," covers limitations—situations where the system works as designed but the design is insufficient:"]}]
2b:["$","ul","ul-11",{"children":["\n",["$","li","li-0",{"children":"Camera blinded by sun glare (no fault, but unsafe)"}],"\n",["$","li","li-1",{"children":"Pedestrian in unusual clothing misclassified"}],"\n",["$","li","li-2",{"children":"Novel road marking pattern not in training data"}],"\n"]}]
