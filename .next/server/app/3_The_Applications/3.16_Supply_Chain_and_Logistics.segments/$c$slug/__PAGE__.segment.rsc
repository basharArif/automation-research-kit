10:["$","ul","ul-6",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"AutoStore"}],": The dominant cube-based AS/RS system powering dense fulfillment for global retailers."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Symbotic"}],": AI-driven robotic fleet moving freely up and down aisles within warehouse racks."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Aurora Driver"}],": L4 autonomous trucking system deployed on Texas freight corridors."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Zipline Platform 2"}],": Next-generation drone delivery utilizing a \"droid\" that lowers packages on a tether for precise delivery."]}],"\n"]}]
