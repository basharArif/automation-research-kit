66:["$","ul","ul-16",{"children":["\n",["$","li","li-0",{"children":"Bots require credentials with elevated access—compromised bots represent insider-threat-level access."}],"\n",["$","li","li-1",{"children":"Principle of least privilege: Bots should have only permissions required for their task."}],"\n",["$","li","li-2",{"children":"Session isolation: Unattended bots run in isolated sessions; prevent credential leakage."}],"\n",["$","li","li-3",{"children":"GDPR compliance: Bots processing PII must log access; data retention policies must apply to bot outputs."}],"\n"]}]
