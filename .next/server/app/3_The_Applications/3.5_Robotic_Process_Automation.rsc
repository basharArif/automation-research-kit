1d:["$","div",null,{"className":"markdown-container","children":[["$","h1","h1-0",{"children":"Sector Brief: Robotic Process Automation (RPA)"}],"\n",["$","p","p-0",{"children":[["$","strong","strong-0",{"children":"Version"}],": 2.0 | ",["$","strong","strong-1",{"children":"Last Updated"}],": 2026-05-07",["$","br","br-0",{}],"\n",["$","strong","strong-2",{"children":"Scope"}],": RPA foundations, hyperautomation, process mining, agentic RPA, market data, tools, ROI"]}],"\n",["$","hr","hr-0",{}],"\n",["$","h2","h2-0",{"children":"See Also"}],"\n",["$","ul","ul-0",{"children":["\n",["$","li","li-0",{"children":[["$","a","a-0",{"href":"3.9_AI_Driven_Automation.md","children":"AI-Driven Automation"}]," — intelligent document processing, LLM-powered automation"]}],"\n",["$","li","li-1",{"children":[["$","a","a-0",{"href":"3.10_Agentic_AI_Automation.md","children":"Agentic AI Automation"}]," — next-generation agentic RPA"]}],"\n",["$","li","li-2",{"children":[["$","a","a-0",{"href":"3.6_Business_Process_Automation.md","children":"Business Process Automation"}]," — broader BPA context"]}],"\n",["$","li","li-3",{"children":[["$","a","a-0",{"href":"../../2_The_Core/2.2_Benchmarks_and_KPIs.md","children":"Benchmarks and KPIs"}]," — RPA performance metrics"]}],"\n"]}],"\n",["$","hr","hr-1",{}],"\n",["$","h2","h2-1",{"children":"1. Overview"}],"\n",["$","p","p-1",{"children":"Robotic Process Automation (RPA) uses software bots to emulate human interactions with digital systems—navigating UIs, entering data, extracting information, and triggering workflows—without modifying underlying systems or requiring APIs. RPA bots interact with applications exactly as humans do: through the user interface layer."}],"\n",["$","p","p-2",{"children":[["$","strong","strong-0",{"children":"Why RPA matters"}],": Many enterprise processes involve repetitive, rule-based digital tasks across fragmented legacy systems that were never designed for integration. RPA provides automation without the cost and risk of system replacement."]}],"\n",["$","p","p-3",{"children":[["$","strong","strong-0",{"children":"Market scale (2025)"}],":"]}],"\n",["$","ul","ul-1",{"children":["\n",["$","li","li-0",{"children":["Global RPA market: ",["$","strong","strong-0",{"children":"$$6.1B"}]," (2025), CAGR 23% through 2030 [Gartner, 2025]"]}],"\n",["$","li","li-1",{"children":["Enterprise adoption: ",["$","strong","strong-0",{"children":"78%"}]," of organizations have implemented or are piloting RPA [Deloitte RPA Survey, 2024]"]}],"\n",["$","li","li-2",{"children":["Planned implementation: ",["$","strong","strong-0",{"children":"92%"}]," of surveyed enterprises plan to increase RPA investment [Deloitte, 2024]"]}],"\n",["$","li","li-3",{"children":"Largest vendor by revenue: UiPath ($1.3B ARR, FY2025); Microsoft Power Automate largest by install base"}],"\n"]}],"\n",["$","hr","hr-2",{}],"\n",["$","h2","h2-2",{"children":"2. How RPA Works"}],"\n",["$","h3","h3-0",{"children":"2.1 Core Mechanism"}],"\n",["$","p","p-4",{"children":["RPA bots operate at the ",["$","strong","strong-0",{"children":"presentation layer"}],"—interacting with applications through UI elements rather than APIs:"]}],"\n",["$","ul","ul-2",{"children":["\n",["$","li","li-0",{"children":"Identify UI elements (buttons, text fields, dropdowns) by properties (ID, XPath, CSS selector, image recognition)"}],"\n",["$","li","li-1",{"children":"Execute UI actions: click, type, read, extract, copy/paste"}],"\n",["$","li","li-2",{"children":"Navigate across applications: web browsers, desktop apps (SAP, Oracle, Excel), email clients, legacy green-screen terminals"}],"\n"]}],"\n",["$","p","p-5",{"children":[["$","strong","strong-0",{"children":"Attended automation"}],": Bot runs on a human worker's desktop, triggered by the worker, assisting in real time. Example: auto-populating CRM fields while on a customer call."]}],"\n",["$","p","p-6",{"children":[["$","strong","strong-0",{"children":"Unattended automation"}],": Bots run autonomously on servers 24/7, triggered by schedules or events. Example: nightly invoice processing batch."]}],"\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a","\n","$L2b","\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50","\n","$L51","\n","$L52","\n","$L53","\n","$L54","\n","$L55","\n","$L56","\n","$L57","\n","$L58","\n","$L59","\n","$L5a","\n","$L5b","\n","$L5c","\n","$L5d","\n","$L5e","\n","$L5f","\n","$L60","\n","$L61","\n","$L62","\n","$L63","\n","$L64","\n","$L65","\n","$L66","\n","$L67","\n","$L68","\n","$L69","\n","$L6a","\n","$L6b","\n","$L6c","\n","$L6d","\n","$L6e"]}]
26:["$","p","p-7",{"children":[["$","strong","strong-0",{"children":"Hybrid automation"}],": Combines attended and unattended; bot handles routine steps and hands off exceptions to humans via task queues."]}]
