64:["$","ul","ul-15",{"children":["\n",["$","li","li-0",{"children":"Bot lifecycle management (development → testing → production → retirement)"}],"\n",["$","li","li-1",{"children":"Change management (UI changes breaking bots)"}],"\n",["$","li","li-2",{"children":"Credential management (bots store credentials—must be secured via PAM tools: CyberArk, HashiCorp Vault)"}],"\n",["$","li","li-3",{"children":"Audit trails and compliance logging"}],"\n",["$","li","li-4",{"children":"Bot performance monitoring and alerting"}],"\n"]}]
