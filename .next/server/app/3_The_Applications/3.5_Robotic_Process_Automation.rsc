28:["$","p","p-8",{"children":"Modern RPA platforms use no-code/low-code visual designers:"}]
29:["$","ol","ol-0",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Record mode"}],": Bot records human actions (clicks, keystrokes) and replays them—fast to build, brittle to UI changes."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Visual workflow designer"}],": Drag-and-drop activity blocks (drag \"Get Web Element\" → \"Click\" → \"Type Into\")—more robust, maintainable."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Scripting"}],": Python/VBScript for complex logic within workflows."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Computer vision"}],": Image-based element identification for legacy systems without accessible element trees (Citrix, VNC environments)."]}],"\n"]}]
