37:["$","ul","ul-5",{"children":["\n",["$","li","li-0",{"children":"PointNet++, PointPillars: Process LIDAR point clouds for 3D object detection in vehicles and warehouse robots."}],"\n",["$","li","li-1",{"children":"ZoeDepth: Monocular depth estimation from RGB cameras, enabling low-cost robot navigation."}],"\n"]}]
38:["$","p","p-10",{"children":[["$","strong","strong-0",{"children":"Performance benchmarks (2025)"}],":"]}]
39:["$","ul","ul-6",{"children":["\n",["$","li","li-0",{"children":"COCO mAP: Best models at 64+ mAP (vs. 37.4 at AlexNet era)"}],"\n",["$","li","li-1",{"children":"Industrial defect detection: <50ms inference on NVIDIA Jetson Orin; <3% false positive rate in leading deployments"}],"\n"]}]
3a:["$","h3","h3-2",{"children":"3.3 Natural Language Processing — Language Interfaces"}]
3b:["$","p","p-11",{"children":[["$","strong","strong-0",{"children":"LLMs in automation (2022–2026)"}],":"]}]
3c:["$","ul","ul-7",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"GPT-4o, Claude 3.7, Gemini 2.0"}],": Multimodal LLMs processing text, images, and structured data. Used for intelligent HMI interfaces, maintenance report parsing, automated documentation."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Task planning from language"}],": LLMs decompose \"sort red boxes from blue boxes\" into robot primitives (perceive → grasp → place). Google's SayCan (2022) demonstrated this at 551 real kitchen tasks [Ahn et al., 2022]."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Intelligent Document Processing (IDP)"}],": LayoutLM, DocFormer extract structured fields from invoices and forms with >95% accuracy. Core to next-generation RPA."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Customer service automation"}],": NLP intent classification reduces average handle time 35–45% [Salesforce, 2024]."]}],"\n"]}]
3d:["$","h3","h3-3",{"children":"3.4 Reinforcement Learning — Learning Control from Interaction"}]
3e:["$","p","p-12",{"children":"RL trains agents through interaction with environments, maximizing cumulative reward. No explicit supervisory labels required—only a reward signal."}]
3f:["$","p","p-13",{"children":[["$","strong","strong-0",{"children":"Key algorithms (2024–2026)"}],":"]}]
40:["$","ul","ul-8",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"PPO (Proximal Policy Optimization)"}],": Most widely deployed; stable, sample-efficient policy gradient method. Default for robot locomotion and manipulation."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"SAC (Soft Actor-Critic)"}],": Maximum-entropy RL; outstanding exploration properties; state-of-the-art for continuous control."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"DreamerV3 (2023)"}],": World-model RL. Learns a latent dynamics model and plans within it. Achieves superhuman performance on diverse tasks with 10× fewer environment interactions [Hafner et al., 2023]."]}],"\n"]}]
41:["$","p","p-14",{"children":[["$","strong","strong-0",{"children":"Real-world RL deployments"}],":"]}]
42:["$","ul","ul-9",{"children":["\n",["$","li","li-0",{"children":"Google DeepMind: RL optimizes datacenter cooling—40% reduction in cooling energy, sustained across 2016–2025 deployments."}],"\n",["$","li","li-1",{"children":"Amazon: RL for warehouse robot dynamic routing and stacking policy."}],"\n",["$","li","li-2",{"children":"NVIDIA: RL for chip floorplanning—1000× faster than human experts [Mirhoseini et al., 2021]."}],"\n"]}]
43:["$","p","p-15",{"children":[["$","strong","strong-0",{"children":"Safe RL"}]," (critical for physical systems):"]}]
44:["$","ul","ul-10",{"children":["\n",["$","li","li-0",{"children":"Constrained MDPs (CMDPs) add hard safety constraints to RL objectives."}],"\n",["$","li","li-1",{"children":"Control Barrier Functions (CBF) certify that system states remain within safe sets."}],"\n",["$","li","li-2",{"children":"Current benchmark: 97.8% task success rate while maintaining safety constraints [Wachi et al., 2024]."}],"\n"]}]
45:["$","hr","hr-4",{}]
46:["$","h2","h2-4",{"children":"4. Foundation Models and Physical AI (2022–2026)"}]
47:["$","p","p-16",{"children":"The most transformative recent development: pre-training massive models on diverse data, then adapting them to physical automation with minimal task-specific data."}]
48:["$","h3","h3-4",{"children":"4.1 Vision-Language Models (VLMs) for Robotics"}]
49:["$","p","p-17",{"children":[["$","strong","strong-0",{"children":"CLIP (2021, OpenAI)"}],": Trains image and text encoders jointly on 400M image-text pairs. Enables open-vocabulary object detection: a robot finds \"the red mug\" without per-class training."]}]
4a:["$","p","p-18",{"children":[["$","strong","strong-0",{"children":"RT-2 (2023, Google DeepMind)"}],": Fine-tuned a 562B-parameter vision-language model (PaLM-E) to output robot actions directly from images and language. Key results:"]}]
4b:["$","ul","ul-11",{"children":["\n",["$","li","li-0",{"children":"62% success on novel tasks never seen during training (vs. 32% for prior methods)"}],"\n",["$","li","li-1",{"children":"Emergent reasoning: robot infers \"place the object that is the color of the sky\" → identifies blue object"}],"\n",["$","li","li-2",{"children":"[Brohan et al., 2023, arXiv:2307.15818]"}],"\n"]}]
4c:["$","p","p-19",{"children":[["$","strong","strong-0",{"children":"RT-X (2023, Google DeepMind + 22 institutions)"}],": Single policy trained across 22 different robot embodiments using the Open X-Embodiment dataset (1M+ trajectories). First evidence that robot policies generalize across morphologies [O'Neill et al., 2023]."]}]
4d:["$","p","p-20",{"children":[["$","strong","strong-0",{"children":"Octo (2024, Berkeley)"}],": Open-source generalist robot policy on Open X-Embodiment data; outperforms baselines on 9 of 14 evaluation tasks. Available: github.com/octo-models/octo."]}]
4e:["$","p","p-21",{"children":[["$","strong","strong-0",{"children":"π0 / pi-zero (2024, Physical Intelligence)"}],": Flow-matching policy trained on diverse manipulation data. Demonstrated dexterous tasks—laundry folding, box assembly—previously near-impossible for robots."]}]
4f:["$","p","p-22",{"children":[["$","strong","strong-0",{"children":"Lerobot (2024, Hugging Face)"}],": Open-source robot learning library with pre-trained policies for common manipulation tasks. Democratizes foundation-model robotics for researchers without large compute."]}]
50:["$","h3","h3-5",{"children":"4.2 Large World Models"}]
51:["$","p","p-23",{"children":[["$","strong","strong-0",{"children":"DreamerV3 (2023, Hafner et al.)"}],": Unified world model learning a compact latent environment representation. Solves Minecraft diamond-mining to robotic control without algorithmic changes."]}]
52:["$","p","p-24",{"children":[["$","strong","strong-0",{"children":"UniSim (2023, OpenAI)"}],": World simulator trained on internet video—generates physically plausible continuations of robot interaction, producing synthetic robot training data at scale."]}]
53:["$","h3","h3-6",{"children":"4.3 Language-Conditioned Robot Control"}]
54:["$","p","p-25",{"children":[["$","strong","strong-0",{"children":"SayCan (2022, Google)"}],": LLM generates high-level action plan (\"get a soda from the fridge\"); robot affordance model selects executable primitives. Demonstrated on 551 real kitchen tasks."]}]
55:["$","p","p-26",{"children":[["$","strong","strong-0",{"children":"Code as Policies (2022, Google)"}],": GPT-4 writes executable Python robot code from natural language—zero-shot generalization to new tasks without robot-specific training."]}]
56:["$","hr","hr-5",{}]
57:["$","h2","h2-5",{"children":"5. Industry Applications"}]
58:["$","h3","h3-7",{"children":"Manufacturing"}]
59:["$","ul","ul-12",{"children":["\n",["$","li","li-0",{"children":"AI vision systems (Cognex ViDi, Landing AI): >99.5% defect detection on PCBs, pharmaceutical pills, textiles."}],"\n",["$","li","li-1",{"children":"Predictive maintenance: GE Aviation ML predicts turbine blade failure, reducing AOG events 20%."}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Siemens Industrial Copilot (2025)"}],": LLM-based assistant generates IEC 61131-3 PLC code from natural language specifications."]}],"\n"]}]
5a:["$","h3","h3-8",{"children":"Logistics and Warehousing"}]
5b:["$","ul","ul-13",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Amazon Robotics (2026)"}],": 750,000+ robots; Sparrow (item picking), Proteus (autonomous ground vehicle), Sequoia (vertical storage)."]}],"\n",["$","li","li-1",{"children":"AMRs (Locus Robotics, MiR): Dynamic path planning, no fixed tracks required; 20%+ CAGR market."}],"\n",["$","li","li-2",{"children":"Last-mile delivery: Starship Technologies (campus), Nuro (road-legal), Serve Robotics (sidewalk)."}],"\n"]}]
5c:["$","h3","h3-9",{"children":"Healthcare"}]
5d:["$","ul","ul-14",{"children":["\n",["$","li","li-0",{"children":"FDA-cleared AI diagnostics: IDx-DR (diabetic retinopathy), Aidoc (radiology triage), Paige (pathology)."}],"\n",["$","li","li-1",{"children":"AlphaFold2 (2021): Predicted 200M protein structures—solving biology's 50-year folding problem. AI-identified drug candidates reached Phase 2 trials by 2025."}],"\n",["$","li","li-2",{"children":"Robotic surgery: da Vinci (12M+ procedures performed); Medtronic Hugo; CMR Surgical Versius."}],"\n"]}]
5e:["$","h3","h3-10",{"children":"Finance"}]
5f:["$","ul","ul-15",{"children":["\n",["$","li","li-0",{"children":"Algorithmic trading: ML executes >70% of US equity volume [TABB Group, 2024]."}],"\n",["$","li","li-1",{"children":"Fraud detection: Graph Neural Network (GNN) models detect fraud in <100ms, <0.1% false positive rate (Visa, Mastercard)."}],"\n"]}]
60:["$","h3","h3-11",{"children":"Energy and Power Grids"}]
61:["$","ul","ul-16",{"children":["\n",["$","li","li-0",{"children":"Google DeepMind RL: 20% increase in wind farm energy value from ML-based power prediction [DeepMind, 2024]."}],"\n",["$","li","li-1",{"children":"Siemens digital twins + ML: 15–25% reduction in wind turbine O&M costs."}],"\n"]}]
62:["$","hr","hr-6",{}]
63:["$","h2","h2-6",{"children":"6. AI Safety and Assurance"}]
64:["$","p","p-27",{"children":"Physical AI requires safety guarantees beyond software testing:"}]
65:["$","p","p-28",{"children":[["$","strong","strong-0",{"children":"Safe RL frameworks"}],": CMDPs, CBFs, Shielding — see §3.4 and ",["$","a","a-0",{"href":"../../4_The_Horizons/4.1_Research_Frontiers.md","children":"4.1_Research_Frontiers.md"}],"."]}]
66:["$","p","p-29",{"children":[["$","strong","strong-0",{"children":"Formal verification of neural networks"}],": Reluplex, Marabou, CROWN verify properties of ReLU networks over input regions. Computationally expensive but advancing rapidly."]}]
67:["$","p","p-30",{"children":[["$","strong","strong-0",{"children":"Explainable AI (XAI)"}],": SHAP (Shapley values), LIME, TCAV. Regulatory driver: ",["$","strong","strong-1",{"children":"EU AI Act"}]," (enforcement August 2026) requires high-risk AI systems to provide explanations to affected persons—now a compliance requirement, not optional."]}]
68:["$","p","p-31",{"children":[["$","strong","strong-0",{"children":"Standards"}],":"]}]
69:["$","table","table-1",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"Standard"}],["$","th","th-1",{"children":"Scope"}],["$","th","th-2",{"children":"Status"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":"EU AI Act"}],["$","td","td-1",{"children":"Risk-based AI regulation; high-risk AI requires conformity assessment"}],["$","td","td-2",{"children":"Enforcement August 2026"}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":"ISO/IEC 42001"}],["$","td","td-1",{"children":"AI management systems"}],["$","td","td-2",{"children":"Published 2023"}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":"ISO/PAS 21448 (SOTIF)"}],["$","td","td-1",{"children":"Safety of intended functionality for AV perception"}],["$","td","td-2",{"children":"Published 2022"}]]}],["$","tr","tr-3",{"children":[["$","td","td-0",{"children":"NIST AI RMF 1.0"}],["$","td","td-1",{"children":"US AI risk management framework"}],["$","td","td-2",{"children":"Published 2023"}]]}]]}]]}]
6a:["$","hr","hr-7",{}]
6b:["$","h2","h2-7",{"children":"7. Challenges"}]
6c:["$","ul","ul-17",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Distribution shift"}],": AI degrades when inputs differ from training data. Mitigation: continual learning, conformal prediction for uncertainty quantification."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Sim-to-real gap"}],": Contact dynamics remain hard to simulate; dexterous manipulation still struggles with real-world transfer despite <3% gap on benchmark tasks."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Explainability vs. performance"}],": More capable models are less interpretable. High-stakes applications require both; neuro-symbolic approaches are an active research area."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Adversarial robustness"}],": Neural networks vulnerable to small input perturbations. Certified defenses (randomized smoothing) provide guarantees but reduce accuracy."]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Energy cost"}],": LLM training requires enormous compute (GPT-4: ~$100M). Edge inference addressed by NVIDIA Jetson Orin (275 TOPS, <30W) and model compression techniques."]}],"\n"]}]
6d:["$","hr","hr-8",{}]
6e:["$","h2","h2-8",{"children":"8. Future Directions"}]
6f:["$","ol","ol-0",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Physical AI at scale"}],": RT-X suggests 10–100× more diverse robot data yields qualitative capability jumps."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Dexterous manipulation"}],": In-hand manipulation (screwing bolts, cloth folding) at 2025 competition: 60–70% success rates. Substantial room to improve."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Lifelong learning"}],": Continuous learning from deployment without catastrophic forgetting."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Human-robot LLM collaboration"}],": Shared mental models, real-time intent prediction, natural language task handoff."]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Neuromorphic edge AI"}],": Intel Loihi 2 (2022): 1000× more energy-efficient than GPUs for sparse inference; applicable to always-on robot perception."]}],"\n"]}]
70:["$","hr","hr-9",{}]
71:["$","h2","h2-9",{"children":"References"}]
72:["$","ul","ul-18",{"children":["\n",["$","li","li-0",{"children":["Brohan, A. et al. (2023). RT-2: Vision-Language-Action Models. ",["$","em","em-0",{"children":"arXiv:2307.15818"}],"."]}],"\n",["$","li","li-1",{"children":["O'Neill, J. et al. (2023). Open X-Embodiment: RT-X Models. ",["$","em","em-0",{"children":"arXiv:2310.08864"}],"."]}],"\n",["$","li","li-2",{"children":["Hafner, D. et al. (2023). Mastering Diverse Domains through World Models (DreamerV3). ",["$","em","em-0",{"children":"arXiv:2301.04104"}],"."]}],"\n",["$","li","li-3",{"children":["Ahn, M. et al. (2022). Do As I Can, Not As I Say: SayCan. ",["$","em","em-0",{"children":"arXiv:2204.01691"}],"."]}],"\n",["$","li","li-4",{"children":["Mirhoseini, A. et al. (2021). A graph placement methodology for fast chip design. ",["$","em","em-0",{"children":"Nature"}],", 594, 207-212."]}],"\n",["$","li","li-5",{"children":["Garcia, J. & Fernández, F. (2015). A comprehensive survey on safe RL. ",["$","em","em-0",{"children":"JMLR"}],", 16(1), 1437-1480."]}],"\n",["$","li","li-6",{"children":["Wachi, A. et al. (2024). Survey of constraint formulations in safe RL. ",["$","em","em-0",{"children":"IJCAI 2024"}],"."]}],"\n",["$","li","li-7",{"children":["Tobin, J. et al. (2017). Domain randomization for sim2real transfer. ",["$","em","em-0",{"children":"IROS 2017"}],"."]}],"\n"]}]
