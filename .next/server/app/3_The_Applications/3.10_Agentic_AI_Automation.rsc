6c:["$","h2","h2-8",{"children":"8. Future Directions"}]
6d:["$","ol","ol-1",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Reliability at scale"}],": Pushing agentic task completion above 80% on complex real-world benchmarks."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Proactive agents"}],": Agents that monitor for opportunities and initiate tasks without being asked."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Cross-agent collaboration standards"}],": Standardized protocols for agents from different vendors to collaborate (analogous to REST for APIs)."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Regulatory framework"}],": EU AI Act and US AI policy increasingly relevant; agentic systems operating with real-world consequences face novel liability questions."]}],"\n",["$","li","li-4",{"children":[["$","strong","strong-0",{"children":"Embodied agents"}],": Physical robots acting as agents—same LLM backbone as software agents, but executing physical actions. See ",["$","a","a-0",{"href":"3.9_AI_Driven_Automation.md","children":"AI-Driven Automation §4"}]," for RT-2, Octo."]}],"\n"]}]
