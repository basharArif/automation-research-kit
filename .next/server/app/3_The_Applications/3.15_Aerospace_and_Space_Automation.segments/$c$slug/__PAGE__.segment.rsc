10:["$","ul","ul-7",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"ClearSpace-1 (ESA)"}],": The first autonomous mission dedicated to removing a piece of space debris from orbit."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Varda Space Industries"}],": Autonomous in-orbit manufacturing capsules returning pharmaceuticals to Earth."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Xwing / Reliable Robotics"}],": Autonomous flight systems for commercial cargo aircraft."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Ingenuity & Successors"}],": Autonomous rotorcraft exploring the Martian surface utilizing vision-based navigation."]}],"\n"]}]
