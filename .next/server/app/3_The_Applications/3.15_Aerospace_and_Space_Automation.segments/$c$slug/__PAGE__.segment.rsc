c:["$","table","table-0",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"Challenge"}],["$","th","th-1",{"children":"Impact"}],["$","th","th-2",{"children":"2026 Automation Solution"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Communication Latency"}]}],["$","td","td-1",{"children":"Teleoperation impossible for Mars/Deep Space"}],["$","td","td-2",{"children":"Fully localized hierarchical task planning using space-hardened edge AI."}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Radiation (SEUs)"}]}],["$","td","td-1",{"children":"Cosmic rays flip bits, crashing neural networks"}],["$","td","td-2",{"children":"Triple Modular Redundancy (TMR) at the software level; robust error-correcting LLM execution."}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Uncooperative Targets"}]}],["$","td","td-1",{"children":"Tumbling debris is unpredictable"}],["$","td","td-2",{"children":"High-frequency Model Predictive Control (MPC) combined with real-time NeRFs (Neural Radiance Fields) for 3D modeling."}]]}],["$","tr","tr-3",{"children":[["$","td","td-0",{"children":["$","strong","strong-0",{"children":"Zero-G Dynamics"}]}],["$","td","td-1",{"children":"Moving a robotic arm rotates the entire spacecraft"}],["$","td","td-2",{"children":"Coupled momentum-control algorithms managing reaction wheels in sync with manipulator joints."}]]}]]}]]}]
