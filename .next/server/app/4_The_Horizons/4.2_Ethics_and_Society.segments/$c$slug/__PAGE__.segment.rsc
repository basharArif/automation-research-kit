9:["$","h2","h2-2",{"children":"2. Reskilling Evidence and Policy"}]
a:["$","h3","h3-3",{"children":"2.1 What Works"}]
b:["$","p","p-6",{"children":[["$","strong","strong-0",{"children":"Proactive vs. reactive reskilling"}],":"]}]
c:["$","ul","ul-5",{"children":["\n",["$","li","li-0",{"children":"Proactive programs (workers trained before displacement): 64% retention in labor market at comparable wages [McKinsey Global Institute, 2023]."}],"\n",["$","li","li-1",{"children":"Reactive programs (workers trained after displacement): 15% retention at comparable wages—a 4× difference in effectiveness [same source]."}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Implication"}],": The window for effective intervention is before job loss, not after. Policy that waits for displacement to act is largely ineffective."]}],"\n"]}]
d:["$","p","p-7",{"children":[["$","strong","strong-0",{"children":"Digital skills as a moderating factor"}],":"]}]
e:["$","ul","ul-6",{"children":["\n",["$","li","li-0",{"children":"Workers with basic digital literacy face 40% lower automation displacement risk than those without [World Bank, 2023]."}],"\n",["$","li","li-1",{"children":"Digital skills programs with employer-designed curricula show 78% job placement rates (vs. 34% for government-only curricula) [OECD, 2024]."}],"\n"]}]
f:["$","p","p-8",{"children":[["$","strong","strong-0",{"children":"Apprenticeship and employer-led models"}],":"]}]
10:["$","ul","ul-7",{"children":["\n",["$","li","li-0",{"children":"German dual system: Apprenticeship programs adapted to automation-era skills show 91% employment rates post-completion [BIBB, 2023]."}],"\n",["$","li","li-1",{"children":"Amazon Career Choice: Internal reskilling for displaced warehouse workers — 95% program completion rate; 3× higher retention than industry average."}],"\n"]}]
11:["$","p","p-9",{"children":[["$","strong","strong-0",{"children":"Government-industry partnership outcomes"}],":"]}]
12:["$","ul","ul-8",{"children":["\n",["$","li","li-0",{"children":"Singapore SkillsFuture: Lifelong learning credit ($500/person), sector-specific training. 98,000 participants (2024); 72% reported career advancement within 2 years."}],"\n",["$","li","li-1",{"children":"US Trade Adjustment Assistance (TAA): Re-trained 1.3M workers (2010–2022); 58% found re-employment within 2 years (criticized as below program investment)."}],"\n",["$","li","li-2",{"children":"EU Just Transition Fund: €17.5B (2021–2027) for regions most impacted by green/digital transition."}],"\n"]}]
13:["$","h3","h3-4",{"children":"2.2 Recommended Policy Framework"}]
14:["$","p","p-10",{"children":[["$","strong","strong-0",{"children":"Education system reform"}],":"]}]
15:["$","ul","ul-9",{"children":["\n",["$","li","li-0",{"children":"STEM + digital literacy from K-12: Critical for next-generation workforce"}],"\n",["$","li","li-1",{"children":"Lifelong learning accounts: Government-funded accounts workers draw for training throughout career (Singapore model, being discussed in EU, Canada)"}],"\n",["$","li","li-2",{"children":"Credentials portability: Micro-credentials recognizable by employers, not just traditional degrees"}],"\n"]}]
16:["$","p","p-11",{"children":[["$","strong","strong-0",{"children":"Social safety net adaptation"}],":"]}]
17:["$","ul","ul-10",{"children":["\n",["$","li","li-0",{"children":"Extended unemployment benefits tied to retraining participation"}],"\n",["$","li","li-1",{"children":"Universal Basic Income (UBI) pilots: Finland (2017–2018, 2,000 participants): recipients reported 6% higher wellbeing; no significant employment reduction. Stockton SEED (2019–2021): 28% full-time employment increase among recipients vs. 25% control."}],"\n",["$","li","li-2",{"children":"Wage insurance: Government supplements income for workers who take lower-wage re-employment (US TAA includes this; reduces wage scarring)"}],"\n"]}]
18:["$","p","p-12",{"children":[["$","strong","strong-0",{"children":"Automation taxation"}],":"]}]
19:["$","ul","ul-11",{"children":["\n",["$","li","li-0",{"children":"\"Robot tax\" proposals: South Korea introduced automation-related tax incentive reduction (2017); Bill Gates advocated for robot tax (2017) to fund reskilling. Economics debate: may slow productivity gains; revenue-neutral approaches preferred by most economists."}],"\n"]}]
1a:["$","hr","hr-3",{}]
1b:["$","h2","h2-3",{"children":"3. Algorithmic Bias and Fairness"}]
1c:["$","h3","h3-5",{"children":"3.1 The Problem"}]
1d:["$","p","p-13",{"children":"AI systems trained on historical data inherit historical biases. When deployed in consequential automation, they can perpetuate and amplify discrimination:"}]
1e:["$","p","p-14",{"children":[["$","strong","strong-0",{"children":"Documented cases"}],":"]}]
1f:["$","ul","ul-12",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Hiring algorithms"}],": Amazon's internal recruiting tool (2018) downgraded resumes with \"women's\" indicators (e.g., \"women's chess club\") because it learned from predominantly male engineering hire patterns. System discontinued [Dastin, 2018]."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Criminal justice"}],": COMPAS recidivism scoring algorithm predicted Black defendants as higher-risk at nearly twice the rate of white defendants with equivalent actual recidivism [Angwin et al., 2016, ProPublica]."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Healthcare resource allocation"}],": Optum algorithm (2019) used healthcare cost as proxy for healthcare need; systematically under-served Black patients who face systemic healthcare access barriers leading to lower costs despite greater need [Obermeyer et al., 2019, Science]."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Facial recognition"}],": Commercial systems (Amazon Rekognition, Microsoft, IBM) showed error rates 10–34× higher for dark-skinned women vs. light-skinned men [Buolamwini & Gebru, 2018]."]}],"\n"]}]
20:["$","h3","h3-6",{"children":"3.2 Mitigation Approaches"}]
21:["$","p","p-15",{"children":[["$","strong","strong-0",{"children":"Pre-processing"}]," (data-level):"]}]
22:["$","ul","ul-13",{"children":["\n",["$","li","li-0",{"children":"Resampling: Oversample underrepresented groups."}],"\n",["$","li","li-1",{"children":"Re-weighting: Assign higher loss weights to minority samples."}],"\n",["$","li","li-2",{"children":"Synthetic data generation: Generate fair synthetic training data."}],"\n"]}]
23:["$","p","p-16",{"children":[["$","strong","strong-0",{"children":"In-processing"}]," (model-level):"]}]
24:["$","ul","ul-14",{"children":["\n",["$","li","li-0",{"children":"Fairness-aware objectives: Constrain demographic parity, equalized odds, or individual fairness during training."}],"\n",["$","li","li-1",{"children":"Adversarial debiasing: Train a classifier + fairness discriminator in adversarial setup."}],"\n"]}]
25:["$","p","p-17",{"children":[["$","strong","strong-0",{"children":"Post-processing"}]," (output-level):"]}]
26:["$","ul","ul-15",{"children":["\n",["$","li","li-0",{"children":"Threshold adjustment per demographic group to equalize false positive/negative rates."}],"\n",["$","li","li-1",{"children":"Calibration: Ensure predicted probabilities match actual outcomes per demographic group."}],"\n"]}]
27:["$","p","p-18",{"children":[["$","strong","strong-0",{"children":"Fairness metrics"}]," (note: cannot simultaneously satisfy all):"]}]
28:["$","ul","ul-16",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Demographic parity"}],": Equal prediction rates across groups."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Equalized odds"}],": Equal TPR and FPR across groups."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Predictive parity"}],": Equal precision across groups."]}],"\n",["$","li","li-3",{"children":"Impossibility theorems: Chouldechova (2017) proved these metrics are mutually incompatible when base rates differ — policy choices determine which to prioritize."}],"\n"]}]
