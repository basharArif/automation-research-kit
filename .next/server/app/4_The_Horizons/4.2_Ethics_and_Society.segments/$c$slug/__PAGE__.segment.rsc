37:["$","ul","ul-20",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Unacceptable risk"}],": Prohibited (social scoring, real-time biometric surveillance)"]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"High risk"}],": Requires conformity assessment, registration, human oversight (AV, medical, hiring, law enforcement)"]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Limited risk"}],": Transparency requirements (chatbots must identify as AI)"]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Minimal risk"}],": Self-regulation (spam filters, game AI)"]}],"\n"]}]
