3e:["$","table","table-3",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"SIL"}],["$","th","th-1",{"children":"Probability of Failure on Demand (PFD)"}],["$","th","th-2",{"children":"Risk Reduction"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":"SIL 1"}],["$","td","td-1",{"children":"10⁻¹ – 10⁻²"}],["$","td","td-2",{"children":"10–100×"}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":"SIL 2"}],["$","td","td-1",{"children":"10⁻² – 10⁻³"}],["$","td","td-2",{"children":"100–1,000×"}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":"SIL 3"}],["$","td","td-1",{"children":"10⁻³ – 10⁻⁴"}],["$","td","td-2",{"children":"1,000–10,000×"}]]}],["$","tr","tr-3",{"children":[["$","td","td-0",{"children":"SIL 4"}],["$","td","td-1",{"children":"10⁻⁴ – 10⁻⁵"}],["$","td","td-2",{"children":"10,000–100,000×"}]]}]]}]]}]
3f:["$","p","p-25",{"children":"Nuclear reactor emergency shutdown systems: SIL 4. Industrial robot e-stop: SIL 2. Consumer product: SIL 1."}]
40:["$","h3","h3-12",{"children":"5.3 Human-in-the-Loop Design Principles"}]
41:["$","p","p-26",{"children":"Even highly automated systems should maintain meaningful human oversight:"}]
42:["$","ul","ul-21",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"Supervisory control"}],": Human sets goals and constraints; automation executes. Human intervenes when confidence is low."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"Override mechanisms"}],": Physical e-stop at arm's reach; software kill switch; authority gradient."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"Alerting and mode awareness"}],": Automation mode clearly communicated; \"automation surprises\" (mode confusion) implicated in aviation accidents (Air France 447, 2009)."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"Transparency by design"}],": System reports confidence levels and flags uncertainty. Low-confidence outputs route to human review."]}],"\n"]}]
43:["$","hr","hr-6",{}]
44:["$","h2","h2-6",{"children":"6. Environmental and Sustainability Implications"}]
45:["$","h3","h3-13",{"children":"6.1 Energy Impact of AI"}]
46:["$","p","p-27",{"children":"Training large AI models is energy-intensive:"}]
47:["$","ul","ul-22",{"children":["\n",["$","li","li-0",{"children":"GPT-4 training: Estimated 25,000 MWh; equivalent to 2,500 US homes for a year."}],"\n",["$","li","li-1",{"children":"Global AI compute energy: Growing 3–4× per year; projected 0.5% of global electricity by 2030 [IEA, 2025]."}],"\n"]}]
48:["$","p","p-28",{"children":[["$","strong","strong-0",{"children":"Positive impacts"}],":"]}]
49:["$","ul","ul-23",{"children":["\n",["$","li","li-0",{"children":"Google's DeepMind RL-based datacenter cooling: 40% reduction in cooling energy, 15% overall energy use reduction."}],"\n",["$","li","li-1",{"children":"Grid optimization: AI dispatch of renewable energy reduces curtailment 10–20%."}],"\n",["$","li","li-2",{"children":"Industrial process optimization: Cement, steel, chemicals — AI optimization reduces energy 5–15% per facility [BCG, 2024]."}],"\n"]}]
4a:["$","h3","h3-14",{"children":"6.2 Physical Robot Environmental Footprint"}]
4b:["$","ul","ul-24",{"children":["\n",["$","li","li-0",{"children":"Collaborative robots (cobots) displace transportation (bringing work to station rather than station to worker) — reduces factory floor space and energy."}],"\n",["$","li","li-1",{"children":"Autonomous agricultural robots: Precision application reduces herbicide/pesticide use 90% (Blue River Technology, John Deere acquisition) [John Deere, 2023]."}],"\n",["$","li","li-2",{"children":"Additive manufacturing automation: Near-zero material waste vs. subtractive CNC (95% material utilization vs. 30–40%)."}],"\n"]}]
4c:["$","hr","hr-7",{}]
