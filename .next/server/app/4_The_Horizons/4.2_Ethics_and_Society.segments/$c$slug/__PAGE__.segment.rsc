2a:["$","ul","ul-17",{"children":["\n",["$","li","li-0",{"children":[["$","strong","strong-0",{"children":"EU AI Act"}],": Prohibits AI systems using subliminal techniques or exploiting vulnerabilities; requires bias risk assessment for high-risk AI; right to explanation."]}],"\n",["$","li","li-1",{"children":[["$","strong","strong-0",{"children":"NYC Local Law 144 (2023)"}],": First US law requiring bias audits for AI-based employment tools; annual third-party auditing required."]}],"\n",["$","li","li-2",{"children":[["$","strong","strong-0",{"children":"EU Employment Equality Directive"}],": Applies to AI-assisted hiring decisions."]}],"\n",["$","li","li-3",{"children":[["$","strong","strong-0",{"children":"US EEOC guidance (2023)"}],": Employers liable under Title VII for AI hiring tool disparate impact on protected classes."]}],"\n"]}]
