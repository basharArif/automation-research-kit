0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"markdown-container","children":[["$","h1","h1-0",{"children":"Socio-Economic & Policy Analysis of Automation"}],"\n",["$","p","p-0",{"children":[["$","strong","strong-0",{"children":"Version"}],": 2.0 | ",["$","strong","strong-1",{"children":"Last Updated"}],": 2026-05-07",["$","br","br-0",{}],"\n",["$","strong","strong-2",{"children":"Scope"}],": Labor economics, job displacement evidence, reskilling programs, policy frameworks, regulatory landscape, algorithmic bias, ethical frameworks"]}],"\n",["$","hr","hr-0",{}],"\n",["$","h2","h2-0",{"children":"See Also"}],"\n",["$","ul","ul-0",{"children":["\n",["$","li","li-0",{"children":[["$","a","a-0",{"href":"4.1_Research_Frontiers.md","children":"Research Frontiers §9"}]," — autonomous policy and ethics"]}],"\n",["$","li","li-1",{"children":[["$","a","a-0",{"href":"4.3_Learning_Roadmap.md","children":"Learning Roadmap §Week 11-12"}]," — ethics curriculum and FMEA"]}],"\n",["$","li","li-2",{"children":[["$","a","a-0",{"href":"../3_The_Applications/3.5_Robotic_Process_Automation.md","children":"RPA Sector Brief"}]," — workforce impact of process automation"]}],"\n"]}],"\n",["$","hr","hr-1",{}],"\n",["$","h2","h2-1",{"children":"1. The Labor Economics of Automation"}],"\n",["$","h3","h3-0",{"children":"1.1 Scale of Displacement — Quantified Evidence"}],"\n",["$","p","p-1",{"children":"The debate about automation's labor impact is empirical, not merely philosophical. The evidence is nuanced: displacement is real and concentrated, but aggregate employment has not collapsed."}],"\n",["$","p","p-2",{"children":[["$","strong","strong-0",{"children":"Middle-skill job reduction"}],":"]}],"\n",["$","ul","ul-1",{"children":["\n",["$","li","li-0",{"children":"23.4% reduction in traditional middle-skill occupations (manufacturing, routine cognitive tasks, logistics) attributable to automation [Acemoglu & Restrepo, 2022]."}],"\n",["$","li","li-1",{"children":"Routine-biased technological change (RBTC): Automation preferentially eliminates routine tasks (whether physical or cognitive), polarizing the labor market into high-skill and low-skill ends [Goos, Manning & Salomons, 2014]."}],"\n",["$","li","li-2",{"children":"US manufacturing employment: Peaked at 19.5M (1979), fell to 12.9M (2024) — a 33% drop. Automation accounts for 80% of this decline; trade accounts for 20% [Acemoglu & Restrepo, 2022]."}],"\n"]}],"\n",["$","p","p-3",{"children":[["$","strong","strong-0",{"children":"New role creation"}],":"]}],"\n",["$","ul","ul-2",{"children":["\n",["$","li","li-0",{"children":"31.7% increase in new employment categories requiring human-AI collaboration, AI development, reskilling support, and digital operations [McKinsey Global Institute, 2023]."}],"\n",["$","li","li-1",{"children":"\"Task reinstatement\" effect: New technologies create tasks humans perform better than machines (client relations, complex problem-solving, ethics review). Historically, reinstatement has offset displacement over multi-decade horizons."}],"\n"]}],"\n",["$","p","p-4",{"children":[["$","strong","strong-0",{"children":"Adaptation gaps"}],":"]}],"\n",["$","ul","ul-3",{"children":["\n",["$","li","li-0",{"children":"42% of displaced workers face adaptation gaps: skill mismatch (required skills not possessed), geographic mismatch (jobs in different cities), or access barriers (training cost, childcare, transportation) [World Economic Forum, 2023]."}],"\n",["$","li","li-1",{"children":"Transition timeline: Workers displaced from manufacturing take on average 2.5–4 years to find comparable-wage employment [Autor, 2019]."}],"\n"]}],"\n",["$","h3","h3-1",{"children":"1.2 Sectoral Breakdown (2024-2026)"}],"\n",["$","table","table-0",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"Sector"}],["$","th","th-1",{"children":"Automation Risk Level"}],"$L2","$L3"]}]}],"$L4"]}],"\n","$L5","\n","$L6","\n","$L7","\n","$L8","\n","$L9","\n","$La","\n","$Lb","\n","$Lc","\n","$Ld","\n","$Le","\n","$Lf","\n","$L10","\n","$L11","\n","$L12","\n","$L13","\n","$L14","\n","$L15","\n","$L16","\n","$L17","\n","$L18","\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21","\n","$L22","\n","$L23","\n","$L24","\n","$L25","\n","$L26","\n","$L27","\n","$L28","\n","$L29","\n","$L2a","\n","$L2b","\n","$L2c","\n","$L2d","\n","$L2e","\n","$L2f","\n","$L30","\n","$L31","\n","$L32","\n","$L33","\n","$L34","\n","$L35","\n","$L36","\n","$L37","\n","$L38","\n","$L39","\n","$L3a","\n","$L3b","\n","$L3c","\n","$L3d","\n","$L3e","\n","$L3f","\n","$L40","\n","$L41","\n","$L42","\n","$L43","\n","$L44","\n","$L45","\n","$L46","\n","$L47","\n","$L48","\n","$L49","\n","$L4a","\n","$L4b","\n","$L4c","\n","$L4d","\n","$L4e","\n","$L4f","\n","$L50"]}],null,"$L51"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"sFzo4LKMJghR7e79YRpfU"}
