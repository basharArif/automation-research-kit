5:["$","h3","h3-2",{"children":"1.3 Gender and Demographic Disparities"}]
6:["$","p","p-5",{"children":"Women face higher automation risk in the near term because they are over-represented in routine cognitive roles (data entry, customer service, administrative processing) that RPA and LLMs target [Brussevich et al., 2018; ILO, 2023]:"}]
7:["$","ul","ul-4",{"children":["\n",["$","li","li-0",{"children":"Women: 11% higher automation exposure index than men globally [ILO, 2023]"}],"\n",["$","li","li-1",{"children":"Low-income countries: 85% of manufacturing jobs at high automation risk (labor arbitrage eliminates protection that existed in wealthy countries) [ILO, 2023]"}],"\n",["$","li","li-2",{"children":"Older workers (55+): Slower skill adaptation rates; lower access to digital upskilling programs. Displacement at this age is highly correlated with permanent labor force exit [OECD, 2023]."}],"\n"]}]
