35:["$","table","table-1",{"children":[["$","thead","thead-0",{"children":["$","tr","tr-0",{"children":[["$","th","th-0",{"children":"Scenario"}],["$","th","th-1",{"children":"Current Legal Position"}],["$","th","th-2",{"children":"Trend"}]]}]}],["$","tbody","tbody-0",{"children":[["$","tr","tr-0",{"children":[["$","td","td-0",{"children":"L2 AV crash (Tesla)"}],["$","td","td-1",{"children":"Driver liable"}],["$","td","td-2",{"children":"Stable"}]]}],["$","tr","tr-1",{"children":[["$","td","td-0",{"children":"L3 AV crash (Mercedes)"}],["$","td","td-1",{"children":"Manufacturer liable (explicit acceptance)"}],["$","td","td-2",{"children":"Manufacturers accepting liability as competitive differentiator"}]]}],["$","tr","tr-2",{"children":[["$","td","td-0",{"children":"Autonomous trucking crash (Aurora)"}],["$","td","td-1",{"children":"Developing; early cases pending"}],["$","td","td-2",{"children":"Likely manufacturer + operator shared"}]]}],["$","tr","tr-3",{"children":[["$","td","td-0",{"children":"Medical AI misdiagnosis"}],["$","td","td-1",{"children":"Physician liable (AI is a tool)"}],["$","td","td-2",{"children":"Under challenge; EU AI Act may change"}]]}],["$","tr","tr-4",{"children":[["$","td","td-0",{"children":"Algorithmic hiring discrimination"}],["$","td","td-1",{"children":"Employer liable (Title VII, EEOC)"}],["$","td","td-2",{"children":"Established"}]]}],["$","tr","tr-5",{"children":[["$","td","td-0",{"children":"RPA data breach"}],["$","td","td-1",{"children":"Deploying organization liable"}],["$","td","td-2",{"children":"Established under GDPR/CCPA"}]]}]]}]]}]
